# Copy to .env and fill in your key
OPENAI_API_KEY=sk-...

# Server port (client dev server proxies to this)
PORT=3001

# Model for real games (game master + inject narratives)
GAME_MODEL=gpt-4.1

# Faster/cheaper model for demo mode (AI players + condensed game master)
DEMO_MODEL=gpt-4.1-mini

# Set to 1 to run without any OpenAI calls (deterministic stub outputs)
LLM_STUB=0
