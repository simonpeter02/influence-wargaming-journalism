{
  "name": "influence-wargaming-journalism",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:stub": "LLM_STUB=1 npm run dev",
    "typecheck": "npm run typecheck --workspaces",
    "test:engine": "npm run test:engine -w server",
    "demo:standalone": "node server.js"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
